"""
Small RNA测序分析流程 - Snakemake流程文件
定义所有分析步骤的规则和依赖关系
"""

import os
import pandas as pd
from pathlib import Path

# 加载配置文件
configfile: "../config/config.yaml"

# 读取样本信息
def get_samples():
    """读取样本信息"""
    if os.path.exists(config["samples"]["metadata_file"]):
        df = pd.read_csv(config["samples"]["metadata_file"])
        samples = df[config["samples"]["sample_column"]].tolist()
        groups = df[config["samples"]["group_column"]].tolist()
        return list(zip(samples, groups))
    else:
        # 如果没有元数据文件，使用默认样本
        return [("GAO_1", "GAO"), ("GAO_2", "GAO"), ("GAO_3", "GAO"),
                ("PAL_1", "PAL"), ("PAL_2", "PAL"), ("PAL_3", "PAL")]

SAMPLES = get_samples()

# 日志配置
LOG_DIR = config["directories"]["logs"]
if not os.path.exists(LOG_DIR):
    os.makedirs(LOG_DIR)

# 输出目录创建规则
rule all:
    """最终目标规则：定义所有输出文件"""
    input:
        # 数据质控
        expand(os.path.join(config["directories"]["results"], "qc", "{sample}_fastqc.html"), sample=[s[0] for s in SAMPLES]),
        os.path.join(config["directories"]["results"], "qc", "qc_summary.csv"),

        # 序列比对
        expand(os.path.join(config["directories"]["results"], "alignment", "{sample}.sorted.bam"), sample=[s[0] for s in SAMPLES]),
        expand(os.path.join(config["directories"]["results"], "alignment", "{sample}_alignment_stats.csv"), sample=[s[0] for s in SAMPLES]),
        os.path.join(config["directories"]["results"], "alignment", "alignment_summary.csv"),

        # 基因计数
        os.path.join(config["directories"]["results"], "counts", "gene_counts.csv"),
        os.path.join(config["directories"]["results"], "counts", "counts_summary.csv"),

        # 差异表达分析
        os.path.join(config["directories"]["results"], "differential_expression", "deseq2_results.csv"),
        os.path.join(config["directories"]["results"], "differential_expression", "filtered_degs.csv"),
        os.path.join(config["directories"]["results"], "differential_expression", "volcano_plot.png"),
        os.path.join(config["directories"]["results"], "differential_expression", "heatmap.png"),

        # Motif分析
        os.path.join(config["directories"]["results"], "motif_analysis", "gene_sequences.fasta"),
        os.path.join(config["directories"]["results"], "motif_analysis", "meme_results", "meme_summary.json"),
        os.path.join(config["directories"]["results"], "motif_analysis", "filtered_motifs.csv"),
        os.path.join(config["directories"]["results"], "motif_analysis", "tomtom_results", "tomtom_summary.json"),
        os.path.join(config["directories"]["results"], "motif_analysis", "visualization", "motif_overview.png")


# ==================== 数据质量控制 ====================

rule run_fastqc:
    """运行FastQC质量控制"""
    input:
        fastq=os.path.join(config["directories"]["raw_fastq"], "{sample}_R1.fastq.gz")
    output:
        html=os.path.join(config["directories"]["results"], "qc", "{sample}_fastqc.html"),
        zip=os.path.join(config["directories"]["results"], "qc", "{sample}_fastqc.zip")
    log:
        os.path.join(LOG_DIR, "fastqc_{sample}.log")
    threads: config["quality_control"]["fastqc"]["threads"]
    shell:
        """
        python scripts/qc/fastqc_analysis.py \
            --input {input.fastq} \
            --output {config[directories][results]}/qc \
            --threads {threads} \
            2>&1 | tee {log}
        """


rule run_trimmomatic:
    """运行Trimmomatic质量修剪"""
    input:
        fastq=os.path.join(config["directories"]["raw_fastq"], "{sample}_R1.fastq.gz")
    output:
        trimmed=os.path.join(config["directories"]["processed"], "{sample}_trimmed.fastq.gz")
    log:
        os.path.join(LOG_DIR, "trimmomatic_{sample}.log")
    threads: config["quality_control"]["trimmomatic"]["threads"]
    shell:
        """
        python scripts/qc/trim_fastq.py \
            --input {input.fastq} \
            --output {output.trimmed} \
            --leading {config[quality_control][trimmomatic][leading]} \
            --trailing {config[quality_control][trimmomatic][trailing]} \
            --slidingwindow '{config[quality_control][trimmomatic][slidingwindow]}' \
            --minlen {config[quality_control][trimmomatic][minlen]} \
            --threads {threads} \
            2>&1 | tee {log}
        """


rule qc_summary:
    """生成质量控制摘要"""
    input:
        expand(os.path.join(config["directories"]["results"], "qc", "{sample}_fastqc.html"), sample=[s[0] for s in SAMPLES]),
        expand(os.path.join(config["directories"]["processed"], "{sample}_trimmed.fastq.gz"), sample=[s[0] for s in SAMPLES])
    output:
        os.path.join(config["directories"]["results"], "qc", "qc_summary.csv")
    log:
        os.path.join(LOG_DIR, "qc_summary.log")
    shell:
        """
        python scripts/qc/qc_summary.py \
            --input-dir {config[directories][results]}/qc \
            --processed-dir {config[directories][processed]} \
            --output {output} \
            2>&1 | tee {log}
        """


# ==================== 序列比对 ====================

rule build_bowtie2_index:
    """构建Bowtie2索引"""
    input:
        fasta=config["reference"]["genome_fasta"]
    output:
        expand("references/bowtie2_index/hg38.{ext}", ext=["1.bt2", "2.bt2", "3.bt2", "4.bt2", "rev.1.bt2", "rev.2.bt2"])
    log:
        os.path.join(LOG_DIR, "build_bowtie2_index.log")
    shell:
        """
        python scripts/alignment/build_bowtie2_index.py \
            --genome {input.fasta} \
            --output references/bowtie2_index \
            --prefix hg38 \
            2>&1 | tee {log}
        """


rule run_bowtie2:
    """运行Bowtie2比对"""
    input:
        fastq=os.path.join(config["directories"]["processed"], "{sample}_trimmed.fastq.gz"),
        index=expand("references/bowtie2_index/hg38.{ext}", ext=["1.bt2", "2.bt2", "3.bt2", "4.bt2", "rev.1.bt2", "rev.2.bt2"])
    output:
        bam=os.path.join(config["directories"]["results"], "alignment", "{sample}.sorted.bam")
    log:
        os.path.join(LOG_DIR, "bowtie2_{sample}.log")
    threads: config["alignment"]["bowtie2"]["threads"]
    shell:
        """
        python scripts/alignment/run_bowtie2.py \
            --input {input.fastq} \
            --output {output.bam} \
            --index references/bowtie2_index/hg38 \
            --preset {config[alignment][bowtie2][preset]} \
            --threads {threads} \
            --seed-length {config[alignment][bowtie2][seed_length]} \
            --max-mismatches {config[alignment][bowtie2][max_mismatches]} \
            2>&1 | tee {log}
        """


rule alignment_stats:
    """计算比对统计信息"""
    input:
        bam=os.path.join(config["directories"]["results"], "alignment", "{sample}.sorted.bam")
    output:
        os.path.join(config["directories"]["results"], "alignment", "{sample}_alignment_stats.csv")
    log:
        os.path.join(LOG_DIR, "alignment_stats_{sample}.log")
    shell:
        """
        python scripts/alignment/alignment_stats.py \
            --input {input.bam} \
            --output {output} \
            2>&1 | tee {log}
        """


rule alignment_summary:
    """生成比对结果摘要"""
    input:
        expand(os.path.join(config["directories"]["results"], "alignment", "{sample}_alignment_stats.csv"), sample=[s[0] for s in SAMPLES])
    output:
        os.path.join(config["directories"]["results"], "alignment", "alignment_summary.csv")
    log:
        os.path.join(LOG_DIR, "alignment_summary.log")
    shell:
        """
        python scripts/alignment/bam_quality_assessment.py \
            --input-dir {config[directories][results]}/alignment \
            --output {output} \
            2>&1 | tee {log}
        """


# ==================== 基因计数 ====================

rule count_features:
    """使用featureCounts计算基因计数"""
    input:
        bams=expand(os.path.join(config["directories"]["results"], "alignment", "{sample}.sorted.bam"), sample=[s[0] for s in SAMPLES]),
        annotation=config["reference"]["gtf_annotation"]
    output:
        counts=os.path.join(config["directories"]["results"], "counts", "gene_counts.csv")
    log:
        os.path.join(LOG_DIR, "count_features.log")
    threads: config["counting"]["featureCounts"]["threads"]
    shell:
        """
        python scripts/expression/count_features.py \
            --bams {input.bams} \
            --annotation {input.annotation} \
            --output {output.counts} \
            --threads {threads} \
            2>&1 | tee {log}
        """


rule counts_summary:
    """生成基因计数摘要"""
    input:
        os.path.join(config["directories"]["results"], "counts", "gene_counts.csv")
    output:
        os.path.join(config["directories"]["results"], "counts", "counts_summary.csv")
    log:
        os.path.join(LOG_DIR, "counts_summary.log")
    shell:
        """
        python scripts/expression/generate_expression_matrix.py \
            --input {input} \
            --output {output} \
            2>&1 | tee {log}
        """


# ==================== 差异表达分析 ====================

rule deseq2_analysis:
    """运行DESeq2差异表达分析"""
    input:
        counts=os.path.join(config["directories"]["results"], "counts", "gene_counts.csv"),
        metadata=config["samples"]["metadata_file"]
    output:
        results=os.path.join(config["directories"]["results"], "differential_expression", "deseq2_results.csv"),
        filtered=os.path.join(config["directories"]["results"], "differential_expression", "filtered_degs.csv"),
        volcano=os.path.join(config["directories"]["results"], "differential_expression", "volcano_plot.png"),
        heatmap=os.path.join(config["directories"]["results"], "differential_expression", "heatmap.png")
    log:
        os.path.join(LOG_DIR, "deseq2_analysis.log")
    shell:
        """
        Rscript scripts/expression/deseq2_analysis.R \
            --counts {input.counts} \
            --metadata {input.metadata} \
            --output-dir {config[directories][results]}/differential_expression \
            --padj-threshold {config[differential_expression][deseq2][padj_threshold]} \
            --log2fc-threshold {config[differential_expression][deseq2][log2fc_threshold]} \
            2>&1 | tee {log}
        """


# ==================== Motif分析 ====================

rule extract_sequences:
    """提取差异表达基因的序列"""
    input:
        degs=os.path.join(config["directories"]["results"], "differential_expression", "filtered_degs.csv"),
        genome=config["reference"]["genome_fasta"],
        annotation=config["reference"]["gtf_annotation"]
    output:
        fasta=os.path.join(config["directories"]["results"], "motif_analysis", "gene_sequences.fasta")
    log:
        os.path.join(LOG_DIR, "extract_sequences.log")
    shell:
        """
        python scripts/motif/extract_sequences.py \
            --genes {input.degs} \
            --genome {input.genome} \
            --annotation {input.annotation} \
            --output {output.fasta} \
            2>&1 | tee {log}
        """


rule run_meme:
    """运行MEME motif分析"""
    input:
        fasta=os.path.join(config["directories"]["results"], "motif_analysis", "gene_sequences.fasta")
    output:
        summary=os.path.join(config["directories"]["results"], "motif_analysis", "meme_results", "meme_summary.json")
    log:
        os.path.join(LOG_DIR, "run_meme.log")
    threads: config["motif_analysis"]["meme"]["threads"]
    shell:
        """
        python scripts/motif/run_meme.py \
            --fasta {input.fasta} \
            --output {config[directories][results]}/motif_analysis/meme_results \
            --width '{config[motif_analysis][meme][min_width]},{config[motif_analysis][meme][max_width]}' \
            --nmotifs {config[motif_analysis][meme][max_motifs]} \
            --evalth {config[motif_analysis][meme][evalue_threshold]} \
            --threads {threads} \
            2>&1 | tee {log}
        """


rule filter_motifs:
    """过滤motif结果"""
    input:
        meme_dir=os.path.join(config["directories"]["results"], "motif_analysis", "meme_results")
    output:
        os.path.join(config["directories"]["results"], "motif_analysis", "filtered_motifs.csv")
    log:
        os.path.join(LOG_DIR, "filter_motifs.log")
    shell:
        """
        python scripts/motif/filter_motifs.py \
            --meme {input.meme_dir} \
            --output {config[directories][results]}/motif_analysis \
            --evalue {config[motif_analysis][filtering][evalue_threshold]} \
            --min-sites {config[motif_analysis][filtering][min_sites]} \
            --min-width {config[motif_analysis][filtering][min_width]} \
            --max-width {config[motif_analysis][filtering][max_width]} \
            2>&1 | tee {log}
        """


rule run_tomtom:
    """运行TomTom motif比较分析"""
    input:
        meme_dir=os.path.join(config["directories"]["results"], "motif_analysis", "meme_results")
    output:
        summary=os.path.join(config["directories"]["results"], "motif_analysis", "tomtom_results", "tomtom_summary.json")
    log:
        os.path.join(LOG_DIR, "run_tomtom.log")
    shell:
        """
        python scripts/motif/tomtom_comparison.py \
            --meme-output {input.meme_dir} \
            --output {config[directories][results]}/motif_analysis/tomtom_results \
            --db {config[motif_analysis][tomtom][database]} \
            --evalth {config[motif_analysis][tomtom][evalue_threshold]} \
            --min-overlap {config[motif_analysis][tomtom][min_overlap]} \
            2>&1 | tee {log}
        """


rule visualize_motifs:
    """可视化motif结果"""
    input:
        meme_dir=os.path.join(config["directories"]["results"], "motif_analysis", "meme_results"),
        filtered_dir=os.path.join(config["directories"]["results"], "motif_analysis")
    output:
        overview=os.path.join(config["directories"]["results"], "motif_analysis", "visualization", "motif_overview.png")
    log:
        os.path.join(LOG_DIR, "visualize_motifs.log")
    shell:
        """
        python scripts/motif/visualize_motifs.py \
            --meme {input.meme_dir} \
            --filtered {input.filtered_dir} \
            --output {config[directories][results]}/motif_analysis/visualization \
            --format {config[visualization][figure_format]} \
            --dpi {config[visualization][dpi]} \
            2>&1 | tee {log}
        """


# ==================== 辅助规则 ====================

rule create_directories:
    """创建输出目录"""
    output:
        os.path.join(config["directories"]["processed"], ".dir_exists"),
        os.path.join(config["directories"]["results"], ".dir_exists"),
        os.path.join(config["directories"]["results"], "qc", ".dir_exists"),
        os.path.join(config["directories"]["results"], "alignment", ".dir_exists"),
        os.path.join(config["directories"]["results"], "counts", ".dir_exists"),
        os.path.join(config["directories"]["results"], "differential_expression", ".dir_exists"),
        os.path.join(config["directories"]["results"], "motif_analysis", ".dir_exists"),
        os.path.join(config["directories"]["results"], "motif_analysis", "meme_results", ".dir_exists"),
        os.path.join(config["directories"]["results"], "motif_analysis", "tomtom_results", ".dir_exists"),
        os.path.join(config["directories"]["results"], "motif_analysis", "visualization", ".dir_exists")
    shell:
        """
        mkdir -p {config[directories][processed]} \
                 {config[directories][results]}/qc \
                 {config[directories][results]}/alignment \
                 {config[directories][results]}/counts \
                 {config[directories][results]}/differential_expression \
                 {config[directories][results]}/motif_analysis/meme_results \
                 {config[directories][results]}/motif_analysis/tomtom_results \
                 {config[directories][results]}/motif_analysis/visualization
        touch {output}
        """

# 设置目录创建规则在其他规则之前运行
for r in rulelist:
    if r.name != "create_directories" and r.name != "all":
        r.input += [os.path.join(config["directories"]["processed"], ".dir_exists")]
